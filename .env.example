# ═══════════════════════════════════════════════════════════
# Nexus Wiki — Environment Variables
# Copy to .env and fill in values.
# Secrets (OPENAI_API_KEY) should go in .env.enc via SOPS.
# Run: bash scripts/decrypt-env.sh to generate .env.runtime
# ═══════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nexus

# Backend
NODE_ENV=development
PORT=4000
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=52428800

# CORS origin (set to your domain in production)
CORS_ORIGIN=https://your-domain.com

# Dev auth bypass — leave EMPTY in production!
DEV_USER_EMAIL=

# Collab WebSocket JWT secret (generate a random string)
COLLAB_JWT_SECRET=change_me_random_secret

# OpenAI (for AI features — optional, put in .env.enc for production)
OPENAI_API_KEY=

# Frontend
VITE_API_BASE_URL=/wiki/api
